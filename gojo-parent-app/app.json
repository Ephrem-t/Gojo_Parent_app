{
  "expo": {
    "name": "Gojo parent",
    "slug": "gojo-parent-app",
    "owner": "eramota3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon-parent.png",
    "scheme": "gojoparentapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon-parent-foreground.png",
        "backgroundColor": "#F4F8FF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.eramota.gojoparentapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon-parent.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#EAF5FF",
          "image": "./assets/images/freepik__talk__16046-removebg-preview.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#08111F",
            "image": "./assets/images/freepik__talk__16046-removebg-preview.png",
            "imageWidth": 240,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "de8d6b69-29d8-4d0a-9d59-51ef853f5a1f"
      }
    }
  }
}
