# Copy this file to .env.local.
# The values below were verified against the live Firebase project.
# Add the remaining public web config values from Firebase Console if you later need them.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=bale-house-rental.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://bale-house-rental-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=bale-house-rental
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=bale-house-rental.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=